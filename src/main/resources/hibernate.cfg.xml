<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!-- 1. Настройки подключения к БД (JDBC) -->
        <property name="hibernate.connection.driver_class">org.h2.Driver</property>
        <property name="hibernate.connection.url">jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;MODE=PostgreSQL</property>
        <property name="hibernate.connection.username">sa</property>
        <property name="hibernate.connection.password"></property>

        <!-- 2. Настройки самого Hibernate (Диалект и поведение) -->
        <!-- Помогает Hibernate генерировать правильный SQL под конкретную БД -->
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</property>

        <!-- Автоматически создает/обновляет таблицы при запуске (как ddl-auto в Spring) -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- 3. Логирование (полезно для учебы, чтобы видеть запросы в консоли) -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>
        <property name="hibernate.highlight_sql">true</property>

        <mapping class="org.example.testrestsoap.entity.jpa.PersonEntity"/>
        <mapping class="org.example.testrestsoap.entity.jpa.PassportEntity"/>
        <mapping class="org.example.testrestsoap.entity.jpa.AddressEntity"/>
        <mapping class="org.example.testrestsoap.entity.jpa.CompanyEntity"/>

        <!-- Если есть CompanyEntity, добавляем её сюда же второй строкой -->
    </session-factory>
</hibernate-configuration>